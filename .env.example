# Copy to .env and fill in. .env is git-ignored; never commit real secrets.

# --- PostgreSQL ---
# POSTGRES_HOST is the Docker Compose service name locally. Override on
# Railway / Synology to point at the managed database host.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=commodity
POSTGRES_USER=commodity
POSTGRES_PASSWORD=change_me

# Port the dashboard is published on (host side).
DASHBOARD_PORT=8000

# --- ETL scheduler (#23) ---
# IANA timezone the ET-anchored slots resolve against (DST-automatic). Defaults
# to America/New_York from config/scheduler.yaml; override only to relocate the
# schedule. Per-slot times live in config/scheduler.yaml, not here.
ETL_TZ=America/New_York

# --- Release calendar (#27) ---
# Optional: override the path to config/release_calendar.yaml (e.g. for tests
# or to supply a host-local calendar outside the image). Defaults to the bundled
# config/release_calendar.yaml when unset.
# RELEASE_CALENDAR_CONFIG=

# --- Data-source API keys (used in later phases; leave blank for now) ---
# FRED:  https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
# EIA:   https://www.eia.gov/opendata/register.php
EIA_API_KEY=
# USDA NASS: https://quickstats.nass.usda.gov/api
USDA_NASS_API_KEY=
# CFTC (Socrata) is open; an app token only raises rate limits. Optional.
CFTC_APP_TOKEN=
